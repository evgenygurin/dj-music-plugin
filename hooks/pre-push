#!/bin/sh
# Prevent direct pushes to main. All changes must go through PR from dev.
# Install: ln -sf ../../hooks/pre-push .git/hooks/pre-push

remote="$1"

while read -r local_ref local_sha remote_ref remote_sha; do
    if echo "$remote_ref" | grep -qE "refs/heads/main$"; then
        # Allow only if pushing dev branch to main (force-sync scenario)
        current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
        if [ "$current_branch" = "main" ]; then
            echo ""
            echo "⛔ Direct push to main is blocked."
            echo "   All changes must go through a PR from dev."
            echo ""
            echo "   To sync main with dev:"
            echo "     git push origin dev:main --force-with-lease"
            echo ""
            exit 1
        fi
    fi
done

exit 0
