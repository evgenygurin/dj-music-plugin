{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT:-${CLAUDE_PLUGIN_ROOT}}/hooks/reload-mcp.sh\"",
            "timeout": 10,
            "statusMessage": "Reloading DJ Music plugin"
          }
        ]
      }
    ]
  }
}
