{
  "description": "Reloads MCP on plugin edits (kills fastmcp stdio so Claude Code respawns with fresh code).",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/reload-mcp.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
