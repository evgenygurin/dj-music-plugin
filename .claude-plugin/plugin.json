{
  "name": "dj-music",
  "version": "0.8.2",
  "description": "DJ techno music library management — MCP tools for set building, audio analysis, playlist expansion, and Yandex Music integration",
  "author": {
    "name": "Evgeny Gurin",
    "url": "https://github.com/evgenygurin"
  },
  "repository": "https://github.com/evgenygurin/dj-music-plugin",
  "license": "MIT",
  "keywords": ["dj", "techno", "music", "mcp", "yandex-music", "set-building", "audio-analysis"],
  "mcpServers": {
    "mcp": {
      "command": "uv",
      "args": ["run", "fastmcp", "run", "fastmcp.json", "--no-banner"],
      "cwd": "${CLAUDE_PLUGIN_ROOT}"
    },
    "db": {
      "command": "bash",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/start-supabase-mcp.sh"]
    }
  }
}
