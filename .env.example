# DJ Music Plugin — Environment Variables
# Copy to .env and fill in required values

# ── Database ──────────────────────────────────────────
DJ_DATABASE_URL=sqlite+aiosqlite:///dj_music.db

# ── DB MCP Server (read-only inspection) ────────────
# Used by the `db` MCP server in .claude-plugin/plugin.json.
# Backed by @supabase/mcp-server-supabase — token at:
# https://supabase.com/dashboard/account/tokens
DJ_DB_ACCESS_TOKEN="sbp_your_personal_access_token"

# ── Yandex Music (required for YM features) ──────────
DJ_YM_TOKEN=your_oauth_token_here
DJ_YM_USER_ID=your_user_id_here
# DJ_YM_BASE_URL=https://api.music.yandex.net
DJ_YM_LIBRARY_PATH=/Users/you/Music/Music/Media.localized/
# DJ_YM_RATE_LIMIT_DELAY=1.5

# ── MCP Server ────────────────────────────────────────
# DJ_PAGINATION_SIZE=20
# DJ_MCP_RETRY_ATTEMPTS=3
# DJ_MCP_RETRY_DELAY=1.0
# DJ_PAYLOAD_LOGGING=false
# DJ_DEBUG=false

# ── Scoring & Optimization ───────────────────────────
# DJ_TRANSITION_CACHE_TTL=3600
# DJ_GA_POPULATION_SIZE=100
# DJ_GA_MAX_GENERATIONS=200
# DJ_GA_MUTATION_RATE=0.15

# ── LLM Sampling (optional — for server-side ctx.sample()) ────────
# Two modes for LLM-assisted tools (e.g. find_similar_tracks strategy="llm"):
#
# 1. CLIENT-DRIVEN (Claude Code MAX, default — no API key needed):
#    Claude Code generates search queries itself and passes them via
#    search_queries=["..."] parameter. Works with any Claude subscription.
#
# 2. SERVER-SIDE (set API key below):
#    ctx.sample() calls Anthropic API via fallback handler.
#    For headless/automated/non-LLM clients.
#
# DJ_ANTHROPIC_API_KEY=sk-ant-...
# DJ_SAMPLING_MODEL=claude-sonnet-4-5
# DJ_SAMPLING_MAX_TOKENS=512

# ── Selectel Cloud (VM for audio analysis) ───────────
# Service user credentials from my.selectel.ru → Account → Service Users
# Download RC file: Service Users → user → Access → RC files → Download
#
# SELECTEL_SSH_HOST=<server_ip>
# SELECTEL_SSH_USER=root
# SELECTEL_SSH_KEY_PATH=~/.ssh/selectel_ed25519
# SELECTEL_PROJECT_PATH=/root/dj-music-plugin
#
# OpenStack API (from RC file):
# OS_AUTH_URL=https://cloud.api.selcloud.ru/identity/v3
# OS_PROJECT_ID=<your_project_id>
# OS_PROJECT_NAME=<your_project_name>
# OS_USER_DOMAIN_NAME=<your_account_id>
# OS_PROJECT_DOMAIN_NAME=<your_account_id>
# OS_USERNAME=<service_user_name>
# OS_PASSWORD=<service_user_password>
# OS_REGION_NAME=ru-1
# OS_IDENTITY_API_VERSION=3
# OS_VOLUME_API_VERSION=3

# ── Observability (optional) ─────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=dj-music
