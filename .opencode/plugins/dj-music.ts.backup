import { readFileSync, existsSync } from "fs"
import { join } from "path"
import type { Plugin } from "@opencode-ai/plugin"
import { tool } from "@opencode-ai/plugin/tool"

function loadDotEnv(projectDir: string): Record<string, string> {
  const envPath = join(projectDir, ".env")
  if (!existsSync(envPath)) return {}
  const vars: Record<string, string> = {}
  for (const line of readFileSync(envPath, "utf-8").split("\n")) {
    const trimmed = line.trim()
    if (!trimmed || trimmed.startsWith("#")) continue
    const eqIdx = trimmed.indexOf("=")
    if (eqIdx === -1) continue
    const key = trimmed.slice(0, eqIdx).trim()
    let value = trimmed.slice(eqIdx + 1).trim()
    if ((value.startsWith("'") && value.endsWith("'")) || (value.startsWith('"') && value.endsWith('"'))) {
      value = value.slice(1, -1)
    }
    vars[key] = value
  }
  return vars
}

export const DjMusicPlugin: Plugin = async (ctx) => {
  const projectDir = ctx.directory
  const env = loadDotEnv(projectDir)

  return {
    "shell.env": async (_input, output) => {
      for (const [key, value] of Object.entries(env)) {
        if (key.startsWith("DJ_") || key.startsWith("SEL_")) {
          output.env[key] = value
        }
      }
    },

    tool: {
      dj_health: tool({
        description: "Check DJ Music Plugin MCP server health and configuration status",
        args: {},
        async execute(_args, _context) {
          const checks: string[] = []
          const errors: string[] = []

          if (env.DJ_DATABASE_URL) checks.push("✅ DATABASE_URL configured")
          else errors.push("❌ DJ_DATABASE_URL missing in .env")

          if (env.DJ_YM_TOKEN) checks.push("✅ Yandex Music token configured")
          else errors.push("❌ DJ_YM_TOKEN missing — can't access Yandex Music")

          if (env.DJ_SUNO_BEARER_TOKEN || env.DJ_SUNO_COOKIE_HEADER) {
            checks.push("✅ Suno credentials configured")
          } else if (env.DJ_SUNO_AUTH_MODE === "api_key" && env.DJ_SUNO_API_KEY) {
            checks.push("✅ Suno API key configured")
          } else {
            errors.push("⚠️  No Suno credentials — generation features disabled")
          }

          if (existsSync(join(projectDir, "server.py"))) {
            checks.push("✅ server.py entrypoint found")
          } else {
            errors.push("❌ server.py not found — MCP server broken")
          }

          const status = errors.length === 0 ? "healthy" : errors.length <= 1 ? "degraded" : "unhealthy"

          return {
            output: `## DJ Music Plugin Health\n\n**Status:** ${status}\n\n${checks.map(c => `- ${c}`).join("\n")}\n${errors.map(e => `- ${e}`).join("\n")}\n\n### MCP Servers\n- **dj** (fastmcp) — loaded in opencode.json\n- **supabase** (read-only Postgres) — loaded in opencode.json`,
            metadata: { status, checks, errors, version: "1.8.0" },
          }
        },
      }),

      dj_env: tool({
        description: "Show active DJ Music environment variables (keys only, values masked)",
        args: {},
        async execute(_args, _context) {
          const safe: Record<string, string> = {}
          for (const [key, value] of Object.entries(env)) {
            if (key.startsWith("DJ_") || key.startsWith("SEL_")) {
              safe[key] = value
                ? value.length > 8
                  ? value.slice(0, 4) + "…" + value.slice(-4)
                  : "****"
                : "(empty)"
            }
          }
          const lines = Object.entries(safe).map(([k, v]) => `- **${k}**: \`${v}\``)
          return {
            output: `## DJ Environment Variables\n\n${lines.join("\n") || "*No DJ_ vars found*"}`,
            metadata: { count: Object.keys(safe).length },
          }
        },
      }),
    },
  }
}
