[importlinter]
root_packages =
    app
include_external_packages = True

# v2 contracts (legacy contracts removed — legacy packages deleted in Phase 7).

# app.v2.audio sits below domain.transition in band ordering. May use
# domain.transition.features (TrackFeatures dataclass) but must not
# reach up into the scorer, DB, transport, providers, or tools.
[importlinter:contract:v2-audio-internal]
name = app.v2.audio must not import DB, transport, providers, tools, or scorer
type = forbidden
source_modules =
    app.v2.audio
forbidden_modules =
    app.v2.db
    app.v2.repositories
    app.v2.providers
    app.v2.handlers
    app.v2.tools
    app.v2.server
    app.v2.domain.transition.scorer
    fastmcp
    httpx
    sqlalchemy

# ── Contract: Resources must not import tools or providers directly ─
[importlinter:contract:v2-resources-no-tools]
name = v2 resources must not import tools, handlers, or provider adapters
type = forbidden
source_modules =
    app.v2.resources
forbidden_modules =
    app.v2.tools
    app.v2.handlers
    app.v2.providers

# ── Contract: Prompts pure (text builders only) ─────────────────────
[importlinter:contract:v2-prompts-pure]
name = v2 prompts must be pure text builders (no repos, tools, providers, DB)
type = forbidden
source_modules =
    app.v2.prompts
forbidden_modules =
    app.v2.repositories
    app.v2.tools
    app.v2.handlers
    app.v2.providers
    app.v2.db
    app.v2.domain
    sqlalchemy
    httpx

# ── Contract: v2 server composition must not pull domain internals ──
[importlinter:contract:v2-server-no-domain]
name = app.v2.server may not import app.v2.domain internals
type = forbidden
source_modules =
    app.v2.server
forbidden_modules =
    app.v2.domain

# ── Contract: v2 REST wrapper must be a thin proxy ──────────────────
# Only DIRECT imports are forbidden — transitive imports via app.v2.server
# are allowed (the server is the REST wrapper's sole composition handle).
[importlinter:contract:v2-rest-no-business]
name = app.v2.rest may only directly import app.v2.server and app.v2.shared
type = forbidden
source_modules =
    app.v2.rest
forbidden_modules =
    app.v2.domain
    app.v2.handlers
    app.v2.tools
    app.v2.resources
    app.v2.prompts
    app.v2.repositories
    app.v2.models
    app.v2.db
    app.v2.providers
    app.v2.audio
allow_indirect_imports = True
