[importlinter]
root_packages =
    dj_music
include_external_packages = True

# ── Contract 1: schemas are pure ────────────────────────────────────
[importlinter:contract:dj-schemas-pure]
name = Schemas must not depend on services or infrastructure
type = forbidden
source_modules = dj_music.schemas
forbidden_modules =
    dj_music.services
    dj_music.ym
    dj_music.tools
    dj_music.engines
    sqlalchemy
    httpx
    fastmcp
    fastapi

# ── Contract 2: core is a leaf ──────────────────────────────────────
[importlinter:contract:dj-core-leaf]
name = Core must not depend on any app layer
type = forbidden
source_modules = dj_music.core
forbidden_modules =
    dj_music.schemas
    dj_music.services
    dj_music.ym
    dj_music.tools
    dj_music.engines

# ── Contract 3: pure domain ─────────────────────────────────────────
[importlinter:contract:dj-pure-domain]
name = Transition, optimization, export, templates must be pure
type = forbidden
source_modules =
    dj_music.transition
    dj_music.optimization
    dj_music.export
    dj_music.templates
forbidden_modules =
    dj_music.models
    dj_music.repositories
    dj_music.services
    dj_music.tools
    dj_music.ym
    dj_music.engines
    sqlalchemy
    httpx
    fastmcp

# ── Contract 4: services are framework-agnostic ─────────────────────
[importlinter:contract:dj-services-no-mcp]
name = Services must be framework-agnostic (no fastmcp / tools imports)
type = forbidden
source_modules =
    dj_music.services
forbidden_modules =
    fastmcp
    dj_music.tools

# ── Contract 5: API stays above persistence ────────────────────────
[importlinter:contract:dj-api-no-db]
name = API layer must not depend on DB models or repositories
type = forbidden
source_modules =
    dj_music.api
forbidden_modules =
    dj_music.models
    dj_music.repositories
ignore_imports =
    dj_music.api.server -> dj_music.di.server_builder

# ── Contract 6: Engines stay below transport ───────────────────────
[importlinter:contract:dj-engines-no-transport]
name = Engines must not depend on API or tools
type = forbidden
source_modules =
    dj_music.engines
forbidden_modules =
    dj_music.api
    dj_music.tools
