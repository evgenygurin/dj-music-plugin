[importlinter]
root_packages =
    app
include_external_packages = True

# v2 contracts (legacy contracts removed — legacy packages deleted in Phase 7).

# app.audio sits below domain.transition in band ordering. May use
# domain.transition.features (TrackFeatures dataclass) but must not
# reach up into the scorer, DB, transport, providers, or tools.
[importlinter:contract:v2-audio-internal]
name = app.audio must not import DB, transport, providers, tools, or scorer
type = forbidden
source_modules =
    app.audio
forbidden_modules =
    app.db
    app.repositories
    app.providers
    app.handlers
    app.tools
    app.server
    app.domain.transition.scorer
    fastmcp
    httpx
    sqlalchemy

# ── Contract: Resources must not import tools or providers directly ─
[importlinter:contract:v2-resources-no-tools]
name = v2 resources must not import tools, handlers, or provider adapters
type = forbidden
source_modules =
    app.resources
forbidden_modules =
    app.tools
    app.handlers
    app.providers

# ── Contract: Prompts pure (text builders only) ─────────────────────
[importlinter:contract:v2-prompts-pure]
name = v2 prompts must be pure text builders (no repos, tools, providers, DB)
type = forbidden
source_modules =
    app.prompts
forbidden_modules =
    app.repositories
    app.tools
    app.handlers
    app.providers
    app.db
    app.domain
    sqlalchemy
    httpx

# ── Contract: v2 server composition must not pull domain internals ──
# Lifespan legitimately instantiates pure-compute domain singletons
# (GA / Greedy / TransitionScorer) per blueprint §11 and publishes them
# on ctx.state. Those two import edges are the only sanctioned crossings;
# everything else (handlers, tools, repos) must still go through app.shared.
# Future cleanup: extract app/registry/algorithms.py with factories so
# lifespan only imports from app.registry.* — see blueprint §3 / §11.
[importlinter:contract:v2-server-no-domain]
name = app.server may not import app.domain internals
type = forbidden
source_modules =
    app.server
forbidden_modules =
    app.domain
ignore_imports =
    app.server.lifespan -> app.domain.optimization
    app.server.lifespan -> app.domain.transition.scorer
    app.handlers.transition_persist -> app.domain.transition.picker
    app.handlers.transition_persist -> app.domain.transition.intent
    app.handlers.transition_persist -> app.domain.transition.recipe
    app.handlers.transition_persist -> app.domain.transition.score
    app.handlers.transition_persist -> app.domain.transition.section_context
    app.handlers.transition_persist -> app.domain.transition.subgenre_rules
    app.repositories.set -> app.domain.render.models

# ── Contract: domain.render stays pure (no IO) ──────────────────────
[importlinter:contract:v2-render-domain-pure]
name = app.domain.render must not import audio, DB, providers, handlers, tools, or server
type = forbidden
source_modules =
    app.domain.render
forbidden_modules =
    app.audio
    app.db
    app.repositories
    app.providers
    app.handlers
    app.tools
    app.server
    librosa
    scipy
    soundfile
