[importlinter]
root_packages =
    app
    dj_music
include_external_packages = True

# ── Contract 1: services must be framework-agnostic ─────────────────
# Services orchestrate domain logic and must not depend on transport (mcp)
# or HTTP frameworks (fastmcp). Reactivated for Phase 7 enforcement.
[importlinter:contract:services-no-mcp]
name = Services must be framework-agnostic (no fastmcp / app.controllers imports)
type = forbidden
source_modules =
    app.services
forbidden_modules =
    fastmcp
    app.controllers

# ── Contract 2: domain layer (transition scoring) is pure ──────────
# Pure mathematical scoring must not touch persistence or framework.
# This already holds — locks the invariant.
[importlinter:contract:transition-pure]
name = Transition scoring must be pure (no DB, no MCP, no HTTP)
type = forbidden
source_modules =
    app.transition
forbidden_modules =
    app.db.repositories
    app.db.models
    app.repositories
    app.models
    app.controllers
    app.services
    app.ym
    fastmcp
    sqlalchemy
    httpx

# ── Contract 3: domain.optimization is pure ─────────────────────────
[importlinter:contract:optimization-pure]
name = Optimization (GA, greedy, fitness) must be pure
type = forbidden
source_modules =
    app.optimization
forbidden_modules =
    app.db.repositories
    app.db.models
    app.repositories
    app.models
    app.controllers
    app.services
    app.ym
    fastmcp
    sqlalchemy
    httpx

# ── Contract 4: utils leaf ──────────────────────────────────────────
[importlinter:contract:utils-leaf]
name = Utils must not depend on app domain code
type = forbidden
source_modules =
    app.core.utils
forbidden_modules =
    app.models
    app.repositories
    app.services
    app.controllers
    app.audio
    app.ym
    app.transition
    app.optimization
    app.templates
    app.audit
    app.export

# ── Contract 5: API stays above persistence ────────────────────────
[importlinter:contract:api-no-db]
name = API layer must not depend on DB models or repositories
type = forbidden
source_modules =
    app.api
forbidden_modules =
    app.db.models
    app.db.repositories
ignore_imports =
    dj_music.api.server -> dj_music.di.server_builder

# ── Contract 6: Engines stay below transport ───────────────────────
[importlinter:contract:engines-no-transport]
name = Engines must not depend on API or controllers
type = forbidden
source_modules =
    app.engines
forbidden_modules =
    app.api
    app.controllers

# ── dj_music contracts ──────────────────────────────────────────────

[importlinter:contract:dj-schemas-pure]
name = Schemas must not depend on services or infrastructure
type = forbidden
source_modules = dj_music.schemas
forbidden_modules =
    dj_music.services
    dj_music.ym
    dj_music.tools
    dj_music.engines
    sqlalchemy
    httpx
    fastmcp
    fastapi

[importlinter:contract:dj-core-leaf]
name = Core must not depend on any app layer
type = forbidden
source_modules = dj_music.core
forbidden_modules =
    dj_music.schemas
    dj_music.services
    dj_music.ym
    dj_music.tools
    dj_music.engines

[importlinter:contract:dj-pure-domain]
name = Transition, optimization, export, templates must be pure
type = forbidden
source_modules =
    dj_music.transition
    dj_music.optimization
    dj_music.export
    dj_music.templates
forbidden_modules =
    dj_music.models
    dj_music.repositories
    dj_music.services
    dj_music.tools
    dj_music.ym
    dj_music.engines
    sqlalchemy
    httpx
    fastmcp
